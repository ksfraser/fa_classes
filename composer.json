{
  "name": "ksfraser/fa-classes",
  "description": "FrontAccounting-specific table classes and related data access helpers.",
  "type": "library",
  "require": {
    "php": ">=7.3",
    "ksfraser/ksf-modules-dao": "^0.5",
    "ksfraser/validation": "^0.1"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/ksfraser/ksf_ModulesDAO.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/ksfraser/Validation.git"
    }
  ],
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "FrontAccounting\\": "src/FrontAccounting/",
      "Ksfraser\\FA\\": "src/Ksfraser/FA/"
    },
    "classmap": [
      "legacy/"
    ],
    "exclude-from-classmap": [
      "legacy/archive/",
      "legacy/class.fa_bank_transfer.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "FrontAccounting\\Tests\\": "tests/",
      "Ksfraser\\FA\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit"
  }
}
