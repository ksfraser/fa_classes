{
  "name": "ksfraser/fa-classes",
  "version": "1.0.0",
  "description": "FrontAccounting-specific table classes and related data access helpers.",
  "type": "library",
  "require": {
    "php": ">=7.3",
    "ksfraser/ksf-modules-dao": "dev-main",
    "ksfraser/validation": "dev-main"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../ksf_ModulesDAO",
      "options": {
        "symlink": false,
        "versions": {
          "ksfraser/ksf-modules-dao": "dev-main"
        }
      }
    },
    {
      "type": "path",
      "url": "../validation",
      "options": {
        "symlink": false,
        "versions": {
          "ksfraser/validation": "dev-main"
        }
      }
    }
  ],
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "FrontAccounting\\": "src/FrontAccounting/",
      "Ksfraser\\FA\\": "src/Ksfraser/FA/"
    },
    "classmap": [
      "legacy/"
    ],
    "exclude-from-classmap": [
      "legacy/archive/",
      "legacy/class.fa_bank_transfer.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "FrontAccounting\\Tests\\": "tests/",
      "Ksfraser\\FA\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit"
  }
}
